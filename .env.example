# Copy this file to .env and fill in your values
# cp .env.example .env

# GitHub Personal Access Token
# Create one at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only is fine)
GITHUB_TOKEN=ghp_your_token_here

# DuckDB path (relative to project root)
DUCKDB_PATH=./pipeline.duckdb

# Number of repos to fetch per topic (max 100 per GitHub API page)
REPOS_PER_TOPIC=50

# Topics to track (comma-separated)
GITHUB_TOPICS=data-engineering,analytics,dbt,python,machine-learning
